{
    "ResourceGroup": {
        "name": "walletpulse-rg",
        "location": "centralindia"
    },
    "AzureContainerRegistry": {
        "resource-group": "walletpulse-rg",
        "name": "walletpulseacr",
        "sku": "Basic",
        "admin-enabled": true
    }, 
    "AzureKubernetesService": {
        "resource-group": "walletpulse-rg",
        "name": "walletpulse-cluster",
        "node-count": 2,
        "node-vm-size": "Standard_B2s_v2",
        "enabled-addons": "monitoring",
        "generate-ssh-keys": true,
        "attach-acr": "walletpulsecr"
    }
}